:: MicroflashOS Proctector [proctector.mcm]

:proctector
set "confirmation="
set "authorized="
echo [proctector] INFO: requesting user authorization >>"%logfile%"
set /p "confirmation=Type "CONFIRM" to authorize this action: "
if "%confirmation%"=="CONFIRM" (
    set "confirmation="
    set "authorized=true"
    echo [proctector] INFO: authorized user %user% >>"%logfile%"
    goto :eof
) else (
    set "confirmation="
    set "authorized=false"
    echo.
    echo User authorization failed!
    echo [kernel] ERROR: user authorization failed >> "%logfile%"
    goto :eof
)
